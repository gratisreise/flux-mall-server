<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fluxmall.domain.member.mapper.ShippingAddressMapper">

  <resultMap id="shippingAddressResultMap" type="com.fluxmall.domain.member.entity.ShippingAddress">
    <id property="id" column="id"/>
    <result property="memberId" column="member_id"/>
    <result property="recipientName" column="recipient_name"/>
    <result property="phone" column="phone"/>
    <result property="postcode" column="postcode"/>
    <result property="address1" column="address1"/>
    <result property="address2" column="address2"/>
    <result property="default" column="is_default"/>
    <result property="createdAt" column="created_at"/>
    <result property="updatedAt" column="updated_at"/>
  </resultMap>

  <select id="findById" resultMap="shippingAddressResultMap"/>
  <select id="findDefaultByMemberId" resultMap="shippingAddressResultMap"/>
  <select id="findAllByMemberId" resultMap="shippingAddressResultMap"/>
  <insert id="save" useGeneratedKeys="true" keyProperty="id"/>
  <update id="update"/>
  <update id="setDefault"/>
  <delete id="deleteById"/>

</mapper>