<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fluxmall.domain.product.mapper.ProductMapper">

  <resultMap id="productResultMap" type="com.fluxmall.domain.product.entity.Product">
    <id property="id" column="id"/>
    <result property="memberId" column="member_id"/>
    <result property="name" column="name"/>
    <result property="description" column="description"/>
    <result property="category" column="category"/>
    <result property="price" column="price"/>
    <result property="stockQuantity" column="stock_quantity"/>
    <result property="productStatus" column="product_status"/>
    <result property="createdAt" column="created_at"/>
    <result property="updatedAt" column="updated_at"/>
  </resultMap>

  <select id="findById" resultMap="productResultMap"/>
  <select id="findAllWithPaging" resultMap="productResultMap"/>
  <select id="searchByKeyword" resultMap="productResultMap"/>
  <insert id="save" useGeneratedKeys="true" keyProperty="id"/>
  <update id="update"/>
  <update id="updateStock"/>
  <update id="softDelete"/>

</mapper>