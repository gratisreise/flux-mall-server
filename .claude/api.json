    "/api/members/register": {
      "post": {
        "summary": "회원가입 (기본 USER 역할)",
        "responses": {},
        "tags": [
          "Member"
        ],
        "description": "비로그인 상태에서 호출. 회원가입 시 기본 역할 = USER",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  },
                  "nickname": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "username": "buyer123@example.com",
                "password": "password123",
                "nickname": "구매자123"
              }
            }
          }
        }
      }
    },
